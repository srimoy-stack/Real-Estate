generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model Listing {
  id                       Int       @id @default(autoincrement())
  listingKey               String    @unique
  listingId                String?
  listPrice                Float?
  standardStatus           String?
  propertyType             String?
  propertySubType          String?
  bedroomsTotal            Int?
  bathroomsTotal           Int?
  address                  String?
  city                     String?
  province                 String?
  postalCode               String?
  latitude                 Float?
  longitude                Float?
  publicRemarks            String?
  agentName                String?
  agentPhone               String?
  officeName               String?
  moreInformationLink      String?
  primaryPhoto             String?
  modificationTimestamp    DateTime?
  listingDate              DateTime?
  rawData                  Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  isFeatured               Boolean   @default(false)
  livingArea               Float?
  yearBuilt                Int?
  isActive                 Boolean   @default(true)
  mediaJson                Json?     @map("media_json")
  photosChangeTimestamp    DateTime? @map("photos_change_timestamp")
  primaryPhotoUrl          String?   @map("primary_photo_url")
  normalized_property_type String?

  @@index([modificationTimestamp])
  @@index([city])
  @@index([listPrice])
  @@index([listingDate])
  @@index([createdAt])
  @@index([isActive, city, listPrice])
  @@index([isActive, normalized_property_type])
  @@index([normalized_property_type])
}

model Lead {
  id             String   @id @default(cuid())
  websiteId      String?
  listingId      String?
  agentId        String?
  mlsNumber      String?
  name           String
  email          String
  phone          String?
  message        String?
  source         String   @default("listing_page")
  status         String   @default("New")
  assignedTo     String?
  isAutoAssigned Boolean  @default(false)
  notes          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model SyncLog {
  id             Int       @id @default(autoincrement())
  trigger        String
  status         String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  listingsSynced Int?
  errorMessage   String?

  @@index([startedAt])
  @@index([status])
}
